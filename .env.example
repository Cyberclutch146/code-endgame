# =============================================
# QuantTerminal — Environment Configuration
# Copy to .env and fill in your values
# =============================================

# --- App ---
APP_ENV=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=trader
DB_PASSWORD=traderpw
DB_NAME=trading
DATABASE_URL=postgresql+asyncpg://trader:traderpw@postgres:5432/trading

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Alpaca Markets (paper trading account — free at alpaca.markets) ---
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=wss://stream.data.alpaca.markets/v2/iex

# --- Paper Trading ---
PAPER_INITIAL_CAPITAL=100000.00

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
